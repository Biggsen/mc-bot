MC_HOST=localhost
MC_PORT=25565
MC_USERNAME=TestBot123
MC_VERSION=
MC_AUTH=offline

BOT_GAMEMODE_ON_SPAWN=creative
BOT_VIEWER_PORT=3999
BOT_CHAT_ON_SPAWN=hello from bot
BOT_RECONNECT=true
BOT_RECONNECT_DELAY_MS=5000

# Village Y recorder (optional). Set both paths to enable "startvillages" chat command.
# VILLAGE_CSV_PATH=./villages.csv
# VILLAGE_OUTPUT_PATH=./villages-with-y.csv
# VILLAGE_TP_Y=320
# VILLAGE_DELAY_AFTER_TP_MS=500
# VILLAGE_WAIT_FOR_GROUND=true
# VILLAGE_GROUND_TIMEOUT_MS=15000

